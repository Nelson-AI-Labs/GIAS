        "data.media": "data_metadata"
      },
      "typed_arrays": {
        "data.descriptions": {
          "discriminator": "type",
          "mappings": {
            "native range": "distribution_and_status",
            "eunis habitat": "habitat_ecology",
            "ecofunctional group": "habitat_ecology",
            "pathway": "introduction_pathways",
