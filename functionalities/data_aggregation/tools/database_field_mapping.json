            "burrowing": "biological_traits",
            "reproduction": "biological_traits",
            "lifecycle": "biological_traits",
            "conservation": "distribution_and_status",
            "materials_examined": "detection_monitoring",
            "Introduced species impact": "impacts",
            "Introduced species vector dispersal": "introduction_pathways",
            "Introduced species abundance": "management_biosecurity"
          }
        }
      },
      "special_handling": {
        "data.descriptions": {
          "condition": "type == 'Introduced species remark' OR type == 'Notes'",
          "action": "map_to_impacts"
        },
        "data.occurrence_sample": {
          "action": "Do not map individual records. Aggregate Lat/Lon data for 'distribution_and_status' heatmaps.",
          "sub_field_mapping": {
            "basisOfRecord": "detection_monitoring"
          }
        }
      },
      "missing_categories": [
        "species_interactions"
      ]
    },
