# GuardIAS secrets — copy this file to .streamlit/secrets.toml and fill in your keys.
# Never commit secrets.toml to version control.

# Required — AI model for data extraction and narrative generation
# Get your key at: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY = ""

# Required — Supplementary search and source finding
# Get your key at: https://app.tavily.com/
TAVILY_API_KEY = ""

# Optional — Google Scholar search via SerpAPI (Google Scholar is skipped without it)
# Get your key at: https://serpapi.com/manage-api-key
SERPAPI_KEY = ""

# Optional — IUCN Red List conservation status data
# Request your token at: https://api.iucnredlist.org/
IUCN_API_KEY = ""

# Optional — AquaNIS aquatic invasive species database
# Request access at: https://www.aquanis.org/ (institutional registration required)
AQUANIS_API_KEY = ""

# Optional — Contact email shown in HTTP User-Agent headers to API providers.
# CONTACT_EMAIL = "your@email.com"
